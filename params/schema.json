{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CI Parameter Spec",
  "description": "Schema for CI parameter validation configuration",
  "type": "object",
  "required": ["version", "parameters"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "parameters": {
      "type": "object",
      "properties": {
        "validation_interval": {
          "type": "string",
          "description": "How often validation runs (e.g., '2h', '6h', '24h')"
        },
        "compliance_level": {
          "type": "string",
          "enum": ["basic", "standard", "strict"]
        },
        "report_format": {
          "type": "string",
          "enum": ["json", "csv", "xml"]
        },
        "retention_policy": {
          "type": "object",
          "properties": {
            "max_age_days": { "type": "integer", "minimum": 1 },
            "compression": { "type": "string" }
          }
        },
        "upstream": {
          "type": "object",
          "properties": {
            "fetch_depth": { "type": "integer", "minimum": 1 },
            "timeout_seconds": { "type": "integer", "minimum": 60 }
          }
        }
      }
    }
  }
}
